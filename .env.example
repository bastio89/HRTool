# ------------------------------------------------------------------
# HRTool - Environment Variables
# Copy this file to .env and adjust for your target environment.
# ------------------------------------------------------------------

# ------------------------------------------------------------
# Core runtime
# ------------------------------------------------------------
PORT=3001
JWT_SECRET=change-me-secure

# ------------------------------------------------------------
# KI-Provider (kompatibel zu bestehenden Ollama-Variablen)
# ------------------------------------------------------------
# Optional: explicit provider mode (ollama | openai | openai-compatible)
LLM_PROVIDER=ollama

# Legacy Ollama-style settings (also used when LLM_PROVIDER=ollama)
# In Container-Umgebungen typischerweise ein externer Ollama-Endpoint (lokal optional über Compose-Profil)
OLLAMA_BASE_URL=http://10.13.13.130:11434
OLLAMA_MODEL=llama3.2
OLLAMA_TIMEOUT_MS=180000

# OpenAI-kompatible Einstellungen
OPENAI_BASE_URL=https://api.openai.com
OPENAI_API_URL=https://api.openai.com
OPENAI_API_KEY=
OPENAI_TIMEOUT_MS=180000
LLM_TIMEOUT_MS=180000
LLM_PING_TIMEOUT_MS=5000
OPENAI_RESPONSE_FORMAT_JSON=false

# Unified model fallback (optional)
LLM_MODEL=llama3.2
OPENAI_MODEL=llama3.2

# ------------------------------------------------------------
# OCR tool paths (macOS + Docker)
# ------------------------------------------------------------
TESSERACT_BIN=/opt/homebrew/opt/tesseract/bin/tesseract
PDFTOPPM_BIN=/opt/homebrew/opt/poppler/bin/pdftoppm

# ------------------------------------------------------------
# Optional n8n / Zusatzintegration
# ------------------------------------------------------------
N8N_ENABLED=false
N8N_BASE_URL=http://localhost:5678
N8N_API_KEY=

# ------------------------------------------------------------
# Traefik / Deployment
# ------------------------------------------------------------
TRAEFIK_HOST=hrtool.local
TRAEFIK_ENTRYPOINT=websecure
TRAEFIK_NETWORK=traefik

