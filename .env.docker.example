# Copy to .env before running docker compose.
JWT_SECRET=bitte-durch-einen-mindestens-32-zeichen-langen-zufallswert-ersetzen
EXTERNAL_API_KEY=

# On macOS/Windows Docker Desktop this reaches Ollama running on the host.
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2

# Optional n8n integration running on the host.
N8N_BASE_URL=http://host.docker.internal:5678
N8N_API_KEY=

FRONTEND_PORT=5173
BACKEND_PORT=3001
